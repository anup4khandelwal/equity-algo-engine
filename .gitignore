# --- Secrets & credentials (NEVER commit) ------------------------------------
.env
.env.*
!.env.example
*.token
*.session
secrets/

# --- Market data dumps -------------------------------------------------------
# Anchored to the repo root so it only ignores the top-level dump directory,
# not source packages named `data` (e.g. src/algotrading/data/).
/data/
*.csv
*.parquet
*.feather
*.h5

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.python-version

# --- Tooling caches ----------------------------------------------------------
.ruff_cache/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# --- Notebooks (strip outputs; don't commit checkpoints) ---------------------
.ipynb_checkpoints/
*-checkpoint.ipynb

# --- OS / editor -------------------------------------------------------------
.DS_Store
.idea/
.vscode/
