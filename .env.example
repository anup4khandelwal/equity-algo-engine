# Copy this file to `.env` and fill in real values. `.env` is gitignored and
# must NEVER be committed. All variables below are read by config/settings.py.

# --- Zerodha Kite Connect ----------------------------------------------------
# From your Kite Connect app at https://developers.kite.trade/
KITE_API_KEY=
KITE_API_SECRET=
# Populated/refreshed daily by scripts/refresh_token.py. Leave blank initially.
KITE_ACCESS_TOKEN=

# --- Storage -----------------------------------------------------------------
# Matches the credentials in docker-compose.yml. psycopg v3 driver.
DATABASE_URL=postgresql+psycopg://algo:algo@localhost:5432/algo
REDIS_URL=redis://localhost:6379/0

# --- Docker Compose (Postgres/TimescaleDB container) -------------------------
POSTGRES_USER=algo
POSTGRES_PASSWORD=algo
POSTGRES_DB=algo

# --- Engine ------------------------------------------------------------------
# paper (default) or live. Live order execution is intentionally stubbed.
TRADING_MODE=paper
